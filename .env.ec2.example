# ============================================================
# Variables de entorno para EC2
# Copiar a .env.ec2 y actualizar con valores reales
# ============================================================

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Base de datos
POSTGRES_USER=cordillera
POSTGRES_PASSWORD=your_secure_password_here

# JWT
JWT_SECRET=your_jwt_secret_key_here

# CORS y dominios permitidos
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://api.yourdomain.com

# Spring profiles (production, staging, development)
SPRING_PROFILES_ACTIVE=production

# Logging
SPRING_LOGGING_LEVEL_ROOT=INFO
SPRING_LOGGING_LEVEL_COM_GRUPOCORDILLERA=DEBUG

# JVM Memory (ajustar según instancia EC2)
# Para t3.micro: 1GB RAM → máximo 256MB para todos (128MB por app)
# Para t3.small: 2GB RAM → máximo 1.5GB para aplicaciones
# Para t3.medium: 4GB RAM → máximo 3GB para aplicaciones
# Para t3.large: 8GB RAM → máximo 6GB para aplicaciones
JAVA_OPTS=-Xms48m -Xmx96m

# Database connection pool
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=20
SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=5

# Time zone
TZ=America/La_Paz

# CONFIGURACIÓN ESPECÍFICA PARA t3.micro
# Descomenta si usas instancia t3.micro

# Para t3.micro: Reducir logging
# SPRING_LOGGING_LEVEL_ROOT=WARN
# SPRING_LOGGING_LEVEL_COM_GRUPOCORDILLERA=INFO

# Para t3.micro: Reducir conexiones a BD
# SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=3
# SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=1

# Para t3.micro: Usar docker-compose-t3micro.yml
# docker-compose -f docker-compose-t3micro.yml up -d

# ============================================================
# PC-B (Servicios) — copiar este archivo como .env y completar
# ============================================================

# IP del PC-C donde corren las bases de datos PostgreSQL
# Ejemplo con las IPs del instituto: DB_HOST=10.199.2.146
DB_HOST=localhost

# Origen del frontend para CORS (IP del PC-A + puerto 5173)
# Ejemplo con las IPs del instituto: CORS_ALLOWED_ORIGINS=http://10.155.25.35:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Credenciales PostgreSQL (deben coincidir con las del PC-C)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Secreto JWT compartido entre api-gateway y ms-clientes
JWT_SECRET=cordillera-jwt-secret-2024-fullstack3-grupo

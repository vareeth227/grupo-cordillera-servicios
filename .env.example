# ============================================================
# CONFIGURACIÓN LOCAL — Grupo Cordillera Servicios
# Copiar este archivo a .env y ajustar los valores
#   cp .env.example .env
# ============================================================

# ── BASE DE DATOS ──────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── SEGURIDAD / JWT ────────────────────────────────────────
# Secreto compartido entre api-gateway y ms-clientes
JWT_SECRET=cordillera-jwt-secret-2024-fullstack3-grupo

# ── CORS / FRONTEND ────────────────────────────────────────
# CASO 1: Frontend y Backend en el MISMO PC
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# CASO 2: Backend en PC-A, Frontend en PC-B (red LAN)
# Reemplaza 192.168.X.Y con la IP real de PC-B (donde corre el frontend)
# Para obtener la IP de PC-B: ejecutar "ipconfig" en PC-B → IPv4 Address
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://192.168.1.100:5173

# ── SPRING BOOT ────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=development
SPRING_JPA_SHOW_SQL=false
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info

# ════════════════════════════════════════════════════════════════
# CONFIGURACIÓN PARA t3.micro - EC2 OPTIMIZADO v2.0
# ════════════════════════════════════════════════════════════════
# 
# Copiar este archivo a .env y actualizar los valores
# cp .env.example .env

# ════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ════════════════════════════════════════════════════════════════

DB_HOST=postgres

# Para acceso remoto desde otra máquina:
# DB_HOST=tu-ec2-ip-publica

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ════════════════════════════════════════════════════════════════
# SECURITY & JWT
# ════════════════════════════════════════════════════════════════

# Secreto JWT compartido entre api-gateway y ms-clientes
# IMPORTANTE: En producción, usar valor fuerte (mínimo 32 caracteres)
JWT_SECRET=cordillera-jwt-secret-2024-fullstack3-grupo

# ════════════════════════════════════════════════════════════════
# CORS & FRONTEND
# ════════════════════════════════════════════════════════════════

# Dominios permitidos (separados por comas)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:9090

# En producción:
# CORS_ALLOWED_ORIGINS=https://tudominio.com

# ════════════════════════════════════════════════════════════════
# SPRING BOOT CONFIGURATION
# ════════════════════════════════════════════════════════════════

SPRING_PROFILES_ACTIVE=production

# Logging level (ERROR para t3.micro, WARN/INFO para debug)
SPRING_LOGGING_LEVEL_ROOT=ERROR

SPRING_JPA_SHOW_SQL=false

# Health check endpoint
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health

# ════════════════════════════════════════════════════════════════
# NOTES & WARNINGS
# ════════════════════════════════════════════════════════════════

# ⚠️  IMPORTANTE: 
# 1. NO guardar .env en control de versiones (git)
# 2. En producción, cambiar POSTGRES_PASSWORD a algo fuerte
# 3. En producción, cambiar JWT_SECRET a valor único
# 4. Usar AWS Secrets Manager en lugar de .env en AWS
#
# 🔧 TROUBLESHOOTING:
# - Si OOM (Out of Memory): Ver docker-compose-t3micro.yml heap limits
# - Si lento: Aumentar JAVA_TOOL_OPTIONS en docker-compose (cuidado RAM)
# - Si conexión rechazada: Verificar DB_HOST y pg_isready
#
# 📊 MONITOREO:
# - docker stats                                   (RAM/CPU)
# - docker-compose logs -f                        (logs)
# - docker exec postgres-cordillera psql -U postgres  (BD)


        },
        {
          "name": "Crear stock",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productoId\": 1,\n  \"cantidad\": 50,\n  \"umbralMinimo\": 10,\n  \"almacen\": \"Almacén Central\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/inventario/stock",
              "host": ["{{base_url}}"],
              "path": ["api", "inventario", "stock"]
            },
            "description": "Registra stock de un producto en un almacén."
          }
        },
        {
          "name": "Actualizar cantidad de stock",
          "request": {

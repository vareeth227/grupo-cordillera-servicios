            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"concepto\": \"Pago arriendo enero\",\n  \"monto\": 800000,\n  \"fecha\": \"2025-01-05\",\n  \"categoria\": \"ARRIENDO\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/financiero/egresos",
              "host": ["{{base_url}}"],
              "path": ["api", "financiero", "egresos"]

            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/financiero/ingresos",
              "host": ["{{base_url}}"],
              "path": ["api", "financiero", "ingresos"]

            },
            "description": "Retorna el catálogo completo de productos.\n\nEjemplo de respuesta:\n[\n  {\n    \"id\": 1,\n    \"codigo\": \"SKU-001\",\n    \"nombre\": \"Laptop Dell\",\n    \"categoria\": \"Electrónica\",\n    \"descripcion\": \"Laptop de alta gama\",\n    \"precio\": 999.99,\n    \"activo\": true\n  }\n]"
          }
        },
        {
          "name": "Listar productos activos",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/inventario/productos/activos",
              "host": ["{{base_url}}"],
              "path": ["api", "inventario", "productos", "activos"]
            },
            "description": "Retorna solo los productos con activo=true."
          }
        },
        {
          "name": "Crear producto",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"codigo\": \"SKU-010\",\n  \"nombre\": \"Monitor Samsung 27\",\n  \"categoria\": \"Electrónica\",\n  \"descripcion\": \"Monitor Full HD 27 pulgadas\",\n  \"precio\": 350000,\n  \"activo\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/inventario/productos",
              "host": ["{{base_url}}"],
              "path": ["api", "inventario", "productos"]
            },
            "description": "Crea un nuevo producto en el catálogo. El campo codigo debe ser único."
          }
        },
        {
          "name": "Listar stock",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/inventario/stock",
              "host": ["{{base_url}}"],

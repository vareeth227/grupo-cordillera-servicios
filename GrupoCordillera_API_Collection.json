{
  "info": {
    "_postman_id": "grupo-cordillera-api-v1",
    "name": "Grupo Cordillera — API REST",
    "description": "Colección completa de endpoints del sistema Grupo Cordillera.\n\nBase URL: {{base_url}} = http://localhost:9090\n\nFlujo de autenticación:\n1. Ejecutar POST /api/clientes/auth/login\n2. Copiar el token de la respuesta\n3. Pegar el valor en la variable 'token' de esta colección\n4. Todos los demás endpoints usan Bearer {{token}} automáticamente",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:9090",
      "type": "string",
      "description": "URL base del API Gateway"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "JWT Bearer Token obtenido desde POST /api/clientes/auth/login"
    }
  ],
  "item": [
    {
      "name": "0. Autenticacion",
      "description": "Endpoint de login. Genera el JWT necesario para el resto de endpoints.",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@grupocordillera.cl\",\n  \"password\": \"admin123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/clientes/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "clientes", "auth", "login"]
            },
            "description": "Retorna un JWT. Copiar el campo 'token' de la respuesta y setearlo en la variable 'token' de la colección.\n\nEjemplo de respuesta:\n{\n  \"token\": \"eyJhbGciOiJIUzI1NiJ9...\",\n  \"tipo\": \"Bearer\",\n  \"email\": \"admin@grupocordillera.cl\",\n  \"rol\": \"ADMIN\"\n}"
          }
        }
      ]
    },
    {
      "name": "1. Ventas",
      "description": "Gestión de puntos de venta y transacciones comerciales. Ruta base: /api/ventas",
      "item": [
        {
          "name": "Listar puntos de venta",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/ventas/puntos",
              "host": ["{{base_url}}"],
              "path": ["api", "ventas", "puntos"]
            },
            "description": "Retorna todos los puntos de venta registrados.\n\nEjemplo de respuesta:\n[\n  {\n    \"id\": 1,\n    \"nombre\": \"Tienda Centro\",\n    \"direccion\": \"Av. Principal 123\",\n    \"region\": \"RM\",\n    \"activo\": true\n  }\n]"
          }
        },
        {
          "name": "Listar puntos de venta activos",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/ventas/puntos/activos",
              "host": ["{{base_url}}"],
              "path": ["api", "ventas", "puntos", "activos"]
            },
            "description": "Retorna solo los puntos de venta con activo=true."
          }
        },
        {
          "name": "Crear punto de venta",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Tienda Norte\",\n  \"direccion\": \"Av. Recoleta 456\",\n  \"region\": \"RM\",\n  \"activo\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/ventas/puntos",
              "host": ["{{base_url}}"],
              "path": ["api", "ventas", "puntos"]
            },
            "description": "Crea un nuevo punto de venta. Retorna HTTP 201 con el recurso creado."
          }
        },
        {
          "name": "Listar transacciones",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/ventas/transacciones",
              "host": ["{{base_url}}"],
              "path": ["api", "ventas", "transacciones"]
            },
            "description": "Retorna todas las transacciones (ventas y devoluciones)."
          }
        },
        {
          "name": "Registrar venta",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fecha\": \"2025-01-15T10:30:00\",\n  \"monto\": 50000,\n  \"puntoDeVentaId\": 1,\n  \"productoCodigo\": \"SKU-001\",\n  \"cantidad\": 2,\n  \"tipo\": \"VENTA\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/ventas/transacciones/venta",
              "host": ["{{base_url}}"],
              "path": ["api", "ventas", "transacciones", "venta"]
            },
            "description": "Registra una venta. El campo tipo se fuerza a VENTA automáticamente."
          }
        },
        {
          "name": "Registrar devolucion",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fecha\": \"2025-01-15T11:00:00\",\n  \"monto\": 50000,\n  \"puntoDeVentaId\": 1,\n  \"productoCodigo\": \"SKU-001\",\n  \"cantidad\": 2,\n  \"tipo\": \"DEVOLUCION\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/ventas/transacciones/devolucion",
              "host": ["{{base_url}}"],
              "path": ["api", "ventas", "transacciones", "devolucion"]
            },
            "description": "Registra una devolución. El campo tipo se fuerza a DEVOLUCION automáticamente."
          }
        },
        {
          "name": "Reporte diario",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/ventas/reporte-diario?fecha=2025-01-15",
              "host": ["{{base_url}}"],
              "path": ["api", "ventas", "reporte-diario"],
              "query": [
                { "key": "fecha", "value": "2025-01-15", "description": "Formato: YYYY-MM-DD" }
              ]
            },
            "description": "Genera un reporte del día indicado con totalVentas, totalDevoluciones, montoNeto y numeroTransacciones.\n\nEjemplo de respuesta:\n{\n  \"fecha\": \"2025-01-15\",\n  \"totalVentas\": 150000.00,\n  \"totalDevoluciones\": 50000.00,\n  \"montoNeto\": 100000.00,\n  \"numeroTransacciones\": 3\n}"
          }
        },
        {
          "name": "Eliminar punto de venta",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/ventas/puntos/1",
              "host": ["{{base_url}}"],
              "path": ["api", "ventas", "puntos", "1"]
            },
            "description": "Elimina el punto de venta con el id indicado. Retorna HTTP 204 sin contenido."
          }
        },
        {
          "name": "Eliminar transaccion",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/ventas/transacciones/1",
              "host": ["{{base_url}}"],
              "path": ["api", "ventas", "transacciones", "1"]
            },
            "description": "Elimina la transacción con el id indicado. Retorna HTTP 204 sin contenido."
          }
        }
      ]
    },
    {
      "name": "2. Ecommerce",
      "description": "Gestión de pedidos online. Ruta base: /api/ecommerce",
      "item": [
        {
          "name": "Listar pedidos",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/ecommerce/pedidos",
              "host": ["{{base_url}}"],
              "path": ["api", "ecommerce", "pedidos"]
            },
            "description": "Retorna todos los pedidos con sus items."
          }
        },
        {
          "name": "Pedidos por cliente",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/ecommerce/pedidos/cliente/1",
              "host": ["{{base_url}}"],
              "path": ["api", "ecommerce", "pedidos", "cliente", "1"]
            },
            "description": "Retorna todos los pedidos del cliente con el id indicado."
          }
        },
        {
          "name": "Pedidos por estado",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/ecommerce/pedidos/estado/PENDIENTE",
              "host": ["{{base_url}}"],
              "path": ["api", "ecommerce", "pedidos", "estado", "PENDIENTE"]
            },
            "description": "Filtra pedidos por estado. Valores: PENDIENTE, CONFIRMADO, EN_ENVIO, ENTREGADO, CANCELADO."
          }
        },
        {
          "name": "Obtener pedido por id",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/ecommerce/pedidos/1",
              "host": ["{{base_url}}"],
              "path": ["api", "ecommerce", "pedidos", "1"]
            },
            "description": "Retorna el pedido completo con sus items. HTTP 404 si no existe."
          }
        },
        {
          "name": "Crear pedido",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clienteId\": 1,\n  \"fechaPedido\": \"2025-01-15T10:30:00\",\n  \"estado\": \"PENDIENTE\",\n  \"total\": 150000,\n  \"direccionDespacho\": \"Av. Las Condes 123, Santiago\",\n  \"items\": [\n    {\n      \"productoCodigo\": \"SKU-001\",\n      \"nombreProducto\": \"Laptop Dell\",\n      \"cantidad\": 1,\n      \"precioUnitario\": 150000\n    }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/ecommerce/pedidos",
              "host": ["{{base_url}}"],
              "path": ["api", "ecommerce", "pedidos"]
            },
            "description": "Crea un nuevo pedido con sus items. Retorna HTTP 201 con el pedido creado."
          }
        },
        {
          "name": "Actualizar estado de pedido",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/ecommerce/pedidos/1/estado?estado=CONFIRMADO",
              "host": ["{{base_url}}"],
              "path": ["api", "ecommerce", "pedidos", "1", "estado"],
              "query": [
                { "key": "estado", "value": "CONFIRMADO", "description": "PENDIENTE | CONFIRMADO | EN_ENVIO | ENTREGADO | CANCELADO" }
              ]
            },
            "description": "Actualiza el estado del pedido. Retorna el pedido actualizado."
          }
        },
        {
          "name": "Eliminar pedido",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/ecommerce/pedidos/1",
              "host": ["{{base_url}}"],
              "path": ["api", "ecommerce", "pedidos", "1"]
            },
            "description": "Elimina el pedido y sus items en cascada. Retorna HTTP 204."
          }
        }
      ]
    },
    {
      "name": "3. Inventario",
      "description": "Gestión de productos y stock. Ruta base: /api/inventario",

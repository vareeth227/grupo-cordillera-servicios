            "description": "Retorna todos los ingresos registrados."
          }
        },
        {
          "name": "Ingresos por periodo",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/financiero/ingresos/periodo?inicio=2025-01-01&fin=2025-01-31",

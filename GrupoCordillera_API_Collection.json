            ],
            "url": {
              "raw": "{{base_url}}/api/inventario/stock/1?cantidad=75",
              "host": ["{{base_url}}"],
              "path": ["api", "inventario", "stock", "1"],
              "query": [
                { "key": "cantidad", "value": "75", "description": "Nueva cantidad disponible" }
              ]
            },
            "description": "Actualiza la cantidad disponible del registro de stock indicado."
          }
        },
        {
          "name": "Alertas de inventario",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/inventario/alertas",
              "host": ["{{base_url}}"],
              "path": ["api", "inventario", "alertas"]
            },
            "description": "Retorna productos cuyo stock actual está por debajo del umbral mínimo.\n\nEjemplo de respuesta:\n[\n  {\n    \"codigoProducto\": \"SKU-001\",\n    \"nombreProducto\": \"Laptop Dell\",\n    \"cantidadActual\": 2,\n    \"umbralMinimo\": 10,\n    \"unidadesFaltantes\": 8\n  }\n]"
          }
        },
        {
          "name": "Eliminar producto",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/inventario/productos/1",
              "host": ["{{base_url}}"],
              "path": ["api", "inventario", "productos", "1"]
            },
            "description": "Elimina el producto con el id indicado. Retorna HTTP 204."
          }
        },
        {
          "name": "Eliminar stock",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/inventario/stock/1",
              "host": ["{{base_url}}"],
              "path": ["api", "inventario", "stock", "1"]
            },
            "description": "Elimina el registro de stock con el id indicado. Retorna HTTP 204."
          }
        }
      ]
    },
    {
      "name": "4. Financiero",
      "description": "Gestión de ingresos, egresos y KPIs financieros. Ruta base: /api/financiero",
      "item": [
        {
          "name": "Listar ingresos",

              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/financiero/egresos/periodo?inicio=2025-01-01&fin=2025-01-31",
              "host": ["{{base_url}}"],
              "path": ["api", "financiero", "egresos", "periodo"],
              "query": [
                { "key": "inicio", "value": "2025-01-01", "description": "Fecha inicio YYYY-MM-DD" },

# ============================================================
# .gitignore - Grupo Cordillera
# ============================================================

# Maven - archivos compilados (se regeneran con mvn)
**/target/
**/.mvn/wrapper/maven-wrapper.jar

# Node - dependencias (se regeneran con npm install)
**/node_modules/
**/dist/

# Variables de entorno y claves privadas (nunca subir)
.env
*.pem
*.key

# IDEs
.idea/
*.iml
.vscode/settings.json
.classpath
.project
.settings/

# Sistemas operativos
.DS_Store
Thumbs.db
